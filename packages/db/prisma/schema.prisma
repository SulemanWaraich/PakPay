generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                   @id @default(autoincrement())
  email              String?               @unique
  name               String?
  number             String                @unique
  password           String
  resetTokenExpiry   DateTime?
  resetTokenHash     String?
  role               UserRole              @default(USER)
  Balance            Balance?
  Dispute            Dispute[]
  merchantProfile    MerchantProfile?
  merchantPayments   MerchantTransaction[] @relation("CustomerTransactions")
  OffRampTransaction OffRampTransaction[]
  OnRampTransaction  OnRampTransaction[]
  sentTransfers      p2pTransfer[]         @relation("FromUserRelation")
  receivedTransfers  p2pTransfer[]         @relation("ToUserRelation")
}

model MerchantProfile {
  id                      Int                   @id @default(autoincrement())
  userId                  Int                   @unique
  businessName            String?
  kycStatus               KycStatus             @default(PENDING)
  createdAt               DateTime              @default(now())
  qrPayload               String?               @unique
  ownerName               String?
  category                MerchantCategory?
  address                 String?
  logoPublicId            String?
  logoUrl                 String?
  addressProofPublicId    String?
  addressProofUrl         String?
  businessLicensePublicId String?
  businessLicenseUrl      String?
  idDocumentPublicId      String?
  idDocumentUrl           String?
  cnicFrontUrl            String?
  cnicBackUrl             String?
  proofOfAddressUrl       String?
  kycSubmittedAt          DateTime?
  kycReviewNote           String?
  auditLogs               AuditLog[]
  user                    User                  @relation(fields: [userId], references: [id])
  transactions            MerchantTransaction[]
  settlements             Settlement[]
}

model MerchantTransaction {
  merchantId    Int
  customerId    Int?
  amount        Int
  paymentMethod PaymentMethod
  status        TransactionStatus
  settled       Boolean           @default(false)
  settledAt     DateTime?
  refunded      Boolean           @default(false)
  refundedAt    DateTime?
  createdAt     DateTime          @default(now())
  ref           String?           @unique
  id            Int               @id @default(autoincrement())
  settlementId  Int?
  Dispute       Dispute[]
  customer      User?             @relation("CustomerTransactions", fields: [customerId], references: [id])
  merchant      MerchantProfile   @relation(fields: [merchantId], references: [id])
  settlement    Settlement?       @relation(fields: [settlementId], references: [id])
}

model Settlement {
  id           Int                   @id @default(autoincrement())
  merchantId   Int
  amount       Int
  status       SettlementStatus      @default(PROCESSING)
  scheduledFor DateTime
  processedAt  DateTime?
  createdAt    DateTime              @default(now())
  transactions MerchantTransaction[]
  merchant     MerchantProfile       @relation(fields: [merchantId], references: [id])
}

model SettlementLock {
  id       Int       @id @default(1)
  locked   Boolean   @default(false)
  lockedAt DateTime?
}

model AuditLog {
  id          Int             @id @default(autoincrement())
  merchantId  Int
  action      String
  reason      String?
  performedBy Int
  createdAt   DateTime        @default(now())
  merchant    MerchantProfile @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

model p2pTransfer {
  id         Int      @id @default(autoincrement())
  amount     Int
  timestamp  DateTime
  fromUserId Int
  toUserId   Int
  fromUser   User     @relation("FromUserRelation", fields: [fromUserId], references: [id])
  toUser     User     @relation("ToUserRelation", fields: [toUserId], references: [id])
}

model OnRampTransaction {
  id        Int          @id @default(autoincrement())
  status    OnRampStatus
  token     String       @unique
  provider  String
  amount    Int
  startTime DateTime
  userId    Int
  user      User         @relation(fields: [userId], references: [id])
}

model OffRampTransaction {
  id                Int           @id @default(autoincrement())
  status            OffRampStatus
  token             String        @unique
  amount            Int
  startTime         DateTime      @default(now())
  userId            Int
  /// Legacy single-line bank label; prefer structured fields below.
  bankAccount       String?
  accountHolderName String?
  bankName          String?
  accountNumber     String?
  branch            String?
  user              User          @relation(fields: [userId], references: [id])
}

model Dispute {
  id                  Int                 @id @default(autoincrement())
  transactionId       Int
  userId              Int
  reason              String
  description         String?
  status              DisputeStatus       @default(PENDING)
  createdAt           DateTime            @default(now())
  resolvedAt          DateTime?
  adminNotes          String?
  MerchantTransaction MerchantTransaction @relation(fields: [transactionId], references: [id])
  User                User                @relation(fields: [userId], references: [id])
}

model Balance {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  amount Int
  locked Int
  user   User @relation(fields: [userId], references: [id])
}

enum UserRole {
  USER
  MERCHANT
  ADMIN
}

enum SettlementStatus {
  PROCESSING
  SUCCESS
  FAILED
  PENDING
}

enum PaymentMethod {
  QR
  CARD
  WALLET
  BANK_TRANSFER
}

enum TransactionStatus {
  SUCCESS
  FAILED
  PENDING
}

enum KycStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

enum MerchantCategory {
  RETAIL
  FOOD
  SERVICES
  TECH
  HEALTHCARE
  EDUCATION
}

enum OnRampStatus {
  Success
  Failure
  Processing
}

enum OffRampStatus {
  Success
  Failure
  Processing
}

enum DisputeStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  REJECTED
}
