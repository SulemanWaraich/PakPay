{
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "cd packages/db && npx prisma generate && cd ../..",
    "db:migrate": "cd packages/db && npx prisma migrate deploy --schema=./prisma/schema.prisma && cd ../..",
    "db:generate:no-engine": "cd packages/db && npx prisma generate --no-engine && cd ../..",
    "start-user-app": "cd ./apps/user-app && npm run start",
    "start-bank-webhook": "cd ./apps/bank-webhook && npm run start",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "vitest": "^2.1.8",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "turbo": "^2.1.3"
  },
  "engines": {
    "node": ">=18"
  },
  "name": "with-tailwind",
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "cloudinary": "^2.9.0",
    "mailer": "^0.6.7",
    "redis": "^5.10.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  }
}
