FROM node:20

WORKDIR /usr/src/app

# Database URLs are supplied at **container runtime** via compose/env_file (not baked into layers).

# NEXT_PUBLIC_* must be present at build time for the client bundle
ARG NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
ARG NEXT_PUBLIC_BASE_URL=http://localhost:3000
ENV NEXT_PUBLIC_SOCKET_URL=$NEXT_PUBLIC_SOCKET_URL
ENV NEXT_PUBLIC_BASE_URL=$NEXT_PUBLIC_BASE_URL

COPY package.json package-lock.json turbo.json ./

COPY apps ./apps
COPY packages ./packages

# Install dependencies
RUN npm ci

# Prisma generate without engines (production safe)
RUN npm run db:generate:no-engine

# Build user app only
RUN npm run build --filter=user-app...

# Copy entrypoint script
COPY entrypoint.sh /usr/src/app/entrypoint.sh
RUN chmod +x /usr/src/app/entrypoint.sh

# Run entrypoint → handles migrations first, then starts app
ENTRYPOINT ["/usr/src/app/entrypoint.sh"]
CMD ["npm", "run", "start-user-app"]