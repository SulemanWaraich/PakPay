# Copy to .env and fill in real values (never commit .env)

DATABASE_URL=postgresql://user:pass@localhost:5432/pakpay
PRISMA_ACCELERATE_URL=

# Public URL customers see in QR codes (must match your live domain in production)
NEXT_PUBLIC_BASE_URL=http://localhost:3005
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
SOCKET_CORS_ORIGIN=http://localhost:3005
# socket-gateway also needs DATABASE_URL, NEXTAUTH_SECRET (or JWT_SECRET)

REDIS_URL=redis://localhost:6379
BANK_WEBHOOK_URL=http://localhost:3003
BANK_WEBHOOK_SECRET=dev-change-me-min-32-characters-long!!

JWT_SECRET=dev-change-me-min-32-characters-long!!
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3005

CRON_SECRET=

# Legacy Gmail SMTP (fallback if SMTP_* not set)
EMAIL_USER=
EMAIL_PASS=

# Primary SMTP for OTP and transactional email (Brevo, SendGrid, etc.)
SMTP_HOST=smtp-relay.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="PakPay <noreply@example.com>"

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

ENFORCE_HTTPS=false
ENABLE_HSTS=false
LOG_LEVEL=info
