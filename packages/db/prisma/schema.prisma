generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                  @id @default(autoincrement())
  email              String?              @unique
  name               String?
  number             String               @unique
  password           String
  role               UserRole             @default(USER)
  Balance            Balance?
  OffRampTransaction OffRampTransaction[]
  OnRampTransaction  OnRampTransaction[]
  sentTransfers      p2pTransfer[]        @relation("FromUserRelation")
  receivedTransfers  p2pTransfer[]        @relation("ToUserRelation")
  resetTokenHash     String?
  resetTokenExpiry   DateTime?
  merchantProfile    MerchantProfile?
  merchantPayments   MerchantTransaction[] @relation("CustomerTransactions")
}


model MerchantProfile {
  id           Int       @id @default(autoincrement())
  ownerName              String?
  userId       Int       @unique
  businessName String?
  category     MerchantCategory?
  address      String?
  logoUrl      String?   // CDN / Cloudinary / S3 URL
  logoPublicId String?   // Cloudinary public_id (optional but recommended)
  kycStatus    KycStatus @default(PENDING)
  createdAt    DateTime  @default(now())
  qrPayload    String?   @unique
  user         User      @relation(fields: [userId], references: [id])
  transactions MerchantTransaction[]
  auditLogs    AuditLog[]
}

model MerchantTransaction {
 id             Int @id @default(autoincrement())

  // 🔗 Relations
  merchantId    Int
  merchant      MerchantProfile @relation(fields: [merchantId], references: [id])

  customerId    Int?
  customer      User? @relation("CustomerTransactions", fields: [customerId], references: [id])

  // 💰 Payment details
  amount        Int
  paymentMethod PaymentMethod
  status        TransactionStatus

  // 🏦 Settlement tracking
  settled       Boolean   @default(false)
  settledAt     DateTime?

  // 🔁 Refunds / disputes (future-proof)
  refunded      Boolean   @default(false)
  refundedAt    DateTime?

  ref           String? @unique

  // 🕒 Timestamps
  createdAt     DateTime  @default(now())
}


model AuditLog {
  id          Int      @id @default(autoincrement())
  merchantId  Int
  action      String
  reason      String?
  performedBy Int
  createdAt   DateTime @default(now())
  merchant    MerchantProfile @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}


model p2pTransfer {
  id         Int      @id @default(autoincrement())
  amount     Int
  timestamp  DateTime
  fromUserId Int
  toUserId   Int
  fromUser   User     @relation("FromUserRelation", fields: [fromUserId], references: [id])
  toUser     User     @relation("ToUserRelation", fields: [toUserId], references: [id])
}

model OnRampTransaction {
  id        Int          @id @default(autoincrement())
  status    OnRampStatus
  token     String       @unique
  provider  String
  amount    Int
  startTime DateTime
  userId    Int
  user      User         @relation(fields: [userId], references: [id])
}

model OffRampTransaction {
  id          Int           @id @default(autoincrement())
  status      OffRampStatus
  token       String        @unique
  amount      Int
  startTime   DateTime      @default(now())
  userId      Int
  bankAccount String
  user        User          @relation(fields: [userId], references: [id])
}

model Balance {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  amount Int
  locked Int
  user   User @relation(fields: [userId], references: [id])
}

enum AuthType {
  Google
  Github
}

enum UserRole {
  USER
  MERCHANT
  ADMIN
}

enum OnRampStatus {
  Success
  Failure
  Processing
}

enum OffRampStatus {
  Success
  Failure
  Processing
}

enum KycStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

enum MerchantCategory {
  RETAIL
  FOOD
  SERVICES
  TECH
  HEALTHCARE
  EDUCATION
}

enum PaymentMethod {
  QR
  CARD
  WALLET
  BANK_TRANSFER
}

enum TransactionStatus {
  SUCCESS
  FAILED
  PENDING
}